var SYS_FB = `你是一个专业的AI教练。请根据用户的回答进行深度打分和反馈。
请严格按照要求的JSON格式输出，确保包含 scores(thought, clarity, honesty, courage, self_awareness, depth), overall, weak_dim, stars_earned, what_worked, what_fell_flat, coach_nudge, stronger_version, encouragement 等字段。

Do NOT use markdown.
Do NOT use line breaks inside string values.
All string values must be under 35 words.
Return ONLY raw JSON.`;


/**
 * ==========================================
 * 2. 核心请求与业务逻辑
 * ==========================================
 */

// 调用 AI 接口的核心函数
function callClaude() {
  // 这里是你原本调用 AI 或者是发送 Fetch/Axios 请求的业务逻辑
  console.log("Claude API Called using SYS_FB constraints...");
}

/**
 * 稳健的 JSON 解析函数（新增）
 * 自动清理 Markdown 标签、截取主结构并提供兜底机制，永不让 App 崩溃
 */
function safeJSON(raw) {
  try {
    // 清理 markdown
    let text = raw
      .replace(/```json/gi, '')
      .replace(/```/g, '')
      .replace(/^json\s*:/i, '')
      .trim();

    // 提取 JSON 主体
    const first = text.indexOf('{');
    const last = text.lastIndexOf('}');

    if (first === -1 || last === -1) {
      throw new Error('No JSON found');
    }

    text = text.slice(first, last + 1);

    // 解析
    const data = JSON.parse(text);

    // 防止空对象
    if (!data || Object.keys(data).length === 0) {
      throw new Error('Empty JSON');
    }

    return data;

  } catch (err) {
    console.error('Broken AI JSON:', raw);

    // 异常兜底，确保前端渲染正常
    return {
      scores: {
        thought: 5,
        clarity: 5,
        honesty: 5,
        courage: 5,
        self_awareness: 5,
        depth: 5
      },
      overall: 5,
      weak_dim: "clarity",
      stars_earned: 2,
      what_worked: "You gave a sincere effort.",
      what_fell_flat: "Your answer needed more detail and examples.",
      coach_nudge: "Try explaining one real experience more clearly.",
      stronger_version: "I learned something important from that experience.",
      encouragement: "Keep practicing. Honest thinking grows slowly."
    };
  }
}

/**
 * AI 响应结果处理回调
 * 已将所有旧的 JSON.parse(raw.replace(...)) 全部替换为 safeJSON
 */
function onAIResponseReceived(raw) {
  
  // 1. 原 var parsed=JSON.parse(raw.replace(/```json|```/g,'').trim()); 已改写：
  var parsed = safeJSON(raw);
  
  // 2. 原 var d=JSON.parse(raw.replace(/```json|```/g,'').trim()); 已改写：
  var d = safeJSON(raw);

  // ==========================================
  // 下面是处理解析后数据的业务逻辑（根据你实际页面调整）
  // ==========================================
  console.log("数据成功解析，已进入安全通道:", parsed || d);
}
</script>
